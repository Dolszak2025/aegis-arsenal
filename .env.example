# Aegis Arsenal Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Application debug mode (True/False)
DEBUG=True

# Application port
APP_PORT=8000

# Application host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost)
APP_HOST=127.0.0.1

# =============================================================================
# VERCEL CONFIGURATION
# =============================================================================

# Vercel project ID (found in vercel.json or dashboard)
VERCEL_PROJECT_ID=your_project_id_here

# Vercel org ID (found in Vercel dashboard)
VERCEL_ORG_ID=your_org_id_here

# Vercel deployment token (for CI/CD)
VERCEL_TOKEN=your_token_here

# =============================================================================
# DATABASE CONFIGURATION (for future use)
# =============================================================================

# Database type (postgresql, mysql, sqlite, mongodb)
# DATABASE_TYPE=postgresql

# Database host
# DATABASE_HOST=localhost

# Database port
# DATABASE_PORT=5432

# Database name
# DATABASE_NAME=aegis_arsenal

# Database user
# DATABASE_USER=postgres

# Database password
# DATABASE_PASSWORD=your_secure_password

# Database connection string (alternative to individual settings)
# DATABASE_URL=postgresql://user:password@localhost:5432/aegis_arsenal

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT algorithm
# JWT_ALGORITHM=HS256

# Access token expiration (in minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (in days)
# REFRESH_TOKEN_EXPIRE_DAYS=7

# API key for external service authentication
# API_KEY=your_api_key_here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials in CORS requests
# CORS_ALLOW_CREDENTIALS=True

# Allowed methods for CORS
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Log format (json, text)
# LOG_FORMAT=text

# Log file path (leave empty for stdout)
# LOG_FILE=logs/app.log

# Enable colored output in logs
# LOG_COLOR=True

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry error tracking URL (if using Sentry)
# SENTRY_DSN=https://your_sentry_url@sentry.io/project_id

# Enable performance monitoring
# ENABLE_PERFORMANCE_MONITORING=True

# =============================================================================
# AI/ML AGENTS CONFIGURATION
# =============================================================================

# Google API key (for Google Drawings integration)
# GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API key (if using OpenAI models)
# OPENAI_API_KEY=your_openai_api_key_here

# Agent timeout (in seconds)
# AGENT_TIMEOUT=30

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================

# Redis URL (for caching and sessions)
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds
# CACHE_TTL=300

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP server
# SMTP_SERVER=smtp.gmail.com

# SMTP port
# SMTP_PORT=587

# SMTP username
# SMTP_USERNAME=your_email@gmail.com

# SMTP password
# SMTP_PASSWORD=your_app_password

# Sender email address
# SENDER_EMAIL=noreply@aegis-arsenal.example.com

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Slack webhook URL (for notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# GitHub token (for API access)
# GITHUB_TOKEN=ghp_your_github_token

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Speed Insights
ENABLE_SPEED_INSIGHTS=True

# Enable API documentation (Swagger UI)
ENABLE_SWAGGER=True

# Enable admin dashboard
ENABLE_ADMIN_DASHBOARD=False

# =============================================================================
# NOTES
# =============================================================================

# 1. Generate secure tokens with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Never commit .env files to version control
# 3. Use .env.local for local development overrides
# 4. Use .env.production for production values (not in repo)
# 5. All commented variables are optional or for future features
